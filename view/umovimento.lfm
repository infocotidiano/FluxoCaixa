  object qrMvto: TZQuery
    Connection = TabGlobal.conexao
    SQL.Strings = (
      'select l.id_lcto, l.data_mvto,p.descricao plano, l.descricao , l.valor , 0.12 saldoatual '
      'from lancamentos l'
      'join planos p on p.id_plano = l.plano'
      'order by 1 limit 1'
    )
    Params = <>
    Left = 608
    Top = 232
