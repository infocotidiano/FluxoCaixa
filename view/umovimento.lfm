  object qrEstatistica: TZQuery
    Connection = TabGlobal.conexao
    SQL.Strings = (
      'select l.plano Plano, p.descricao Descricao, sum(l.valor*-1) SubTotal, '
      'sum((l.valor*-1)/tmp.total*100) Percentual'
      'from lancamentos l'
      'join planos p on p.id_plano = l.plano,'
      '(select sum(valor*-1) Total'
      'from lancamentos'
      'where valor < 0 and conta = 1 '
      'and data_mvto between ''2022-09-02'' and ''2022-10-02'') tmp'
      'where p.tipo  = ''D'' and l.conta = 1'
      'and l.data_mvto between ''2022-09-02'' and ''2022-10-02'''
      'group by l.plano, p.descricao'
    )
    Params = <>
    Left = 200
    Top = 280
    object qrEstatisticaPlano: TLongintField
      FieldKind = fkData
      FieldName = 'Plano'
      Index = 0
      LookupCache = False
