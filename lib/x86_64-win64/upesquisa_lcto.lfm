  object qrPESQ: TZQuery
    Connection = TabGlobal.conexao
    SQL.Strings = (
      'select l.id_lcto LCTO, l.data_mvto DATA, l.plano PLANO,'
      'p.descricao DESC_PLANO, l.descricao DESCRICAO, l.valor VALOR, '
      'p.tipo TIPO  '
      'from lancamentos l '
      'join planos p on p.id_plano = l.plano'
    )
    Params = <>
    Left = 265
    Top = 296
